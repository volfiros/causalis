# ---------------------------------------------------------------------------
# Backend URL
# ---------------------------------------------------------------------------
# For local development:  http://localhost:8000
# For production:          Set this to your deployed backend URL
#                          (e.g. https://api.causalis.ai)
#
# All API calls are proxied through Next.js rewrites, so this is the only
# URL you need to configure — no NEXT_PUBLIC_ vars are required.
# ---------------------------------------------------------------------------
BACKEND_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Gemini API
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest